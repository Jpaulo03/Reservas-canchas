<%- include('../partials/header') %>
<h2 class="mb-4">Panel de Control: Todas las Reservas</h2>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Usuario</th>
                    <th>Cancha</th>
                    <th>Fecha / Hora</th>
                    <th>Estado</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                <% reservas.forEach(r => { %>
                    <tr>
                        <td>
                            <strong><%= r.Usuario.nombre %></strong><br>
                            <small class="text-muted"><%= r.Usuario.email %></small>
                        </td>
                        <td><%= r.Horario.Cancha.nombre %></td>
                        <td>
                            <%= r.Horario.fecha %><br>
                            <span class="badge bg-light text-dark border">
                                <%= r.Horario.hora_inicio %> - <%= r.Horario.hora_fin %>
                            </span>
                        </td>
                        <td>
                            <span class="badge <%= r.estado === 'confirmada' ? 'bg-success' : 'bg-danger' %>">
                                <%= r.estado %>
                            </span>
                        </td>
                        <td>
                            <form action="/admin/reservas/estado/<%= r.id %>" method="POST" class="input-group input-group-sm">
                                <select name="nuevo_estado" class="form-select">
                                    <option value="confirmada" <%= r.estado === 'confirmada' ? 'selected' : '' %>>Confirmar</option>
                                    <option value="cancelada" <%= r.estado === 'cancelada' ? 'selected' : '' %>>Cancelar</option>
                                </select>
                                <button class="btn btn-outline-primary">Actualizar</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<%- include('../partials/footer') %>