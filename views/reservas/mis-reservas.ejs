<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Mis Reservas</h2>
    <a href="/canchas" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-plus-lg"></i> Nueva Reserva
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Cancha</th>
                        <th>Fecha</th>
                        <th>Horario</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (reservas.length === 0) { %>
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-calendar-x d-block mb-2 fs-2"></i>
                                Aún no tienes reservas realizada.
                            </td>
                        </tr>
                    <% } %>
                    
                    <% reservas.forEach(reserva => { %>
                        <tr>
                            <td class="fw-bold"><%= reserva.Horario.Cancha.nombre %></td>
                            <td><%= reserva.Horario.fecha %></td>
                            <td>
                                <span class="badge bg-light text-dark border">
                                    <%= reserva.Horario.hora_inicio %> - <%= reserva.Horario.hora_fin %>
                                </span>
                            </td>
                            <td>
                                <% if (reserva.estado === 'confirmada') { %>
                                    <span class="badge bg-success-subtle text-success border border-success">Confirmada</span>
                                <% } else { %>
                                    <span class="badge bg-danger-subtle text-danger border border-danger">Cancelada</span>
                                <% } %>
                            </td>
                            <td class="text-end">
                                <% if (reserva.estado === 'confirmada') { %>
                                    <div class="btn-group">
                                        <form action="/reservas/cancelar/<%= reserva.id %>" method="POST" onsubmit="return confirm('¿Estás seguro de que deseas cancelar esta reserva?')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Cancelar</button>
                                        </form>
                                        <a href="/resenas/nueva/<%= reserva.Horario.Cancha.id %>" class="btn btn-sm btn-outline-secondary ms-2">Dejar Reseña</a>
                                    </div>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<%- include('../partials/footer') %>