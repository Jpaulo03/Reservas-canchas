<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Tipos de Cancha</h2>
    <a href="/admin/tipos/nuevo" class="btn btn-success">Nuevo Tipo</a>
</div>

<table class="table table-bordered bg-white shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th class="text-center">Acciones</th>
        </tr>
    </thead>
    <tbody>
        <% tipos.forEach(t => { %>
            <tr>
                <td><%= t.id %></td>
                <td><%= t.nombre %></td>
                <td class="text-center">
                    <a href="/admin/tipos/editar/<%= t.id %>" class="btn btn-sm btn-warning">Editar</a>
                    <form action="/admin/tipos/eliminar/<%= t.id %>" method="POST" class="d-inline" onsubmit="return confirm('¿Borrar este tipo?')">
                        <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                    </form>
                </td>
            </tr>
        <% }) %>
    </tbody>
</table>
<%- include('../partials/footer') %>