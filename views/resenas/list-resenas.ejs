<%- include('../partials/header') %>
<div class="mb-4">
    <h2>Reseñas de <%= cancha.nombre %></h2>
    <a href="/canchas" class="btn btn-outline-secondary btn-sm">Volver</a>
</div>

<div class="row">
    <% if (resenas.length === 0) { %>
        <div class="col-12 text-center py-5">
            <p class="text-muted">Aún no hay reseñas para esta cancha.</p>
        </div>
    <% } %>
    <% resenas.forEach(r => { %>
        <div class="col-md-6 mb-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <h6 class="fw-bold"><%= r.Usuario.nombre %></h6>
                        <span class="text-warning">
                            <%= "⭐".repeat(r.calificacion) %>
                        </span>
                    </div>
                    <p class="mb-0 text-muted fst-italic">"<%= r.comentario %>"</p>
                </div>
            </div>
        </div>
    <% }) %>
</div>
<%- include('../partials/footer') %>