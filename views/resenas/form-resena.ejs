<%- include('../partials/header') %>
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-body">
                <h3>Calificar: <%= cancha.nombre %></h3>
                <form action="/resenas/nueva/<%= cancha.id %>" method="POST">
                    <div class="mb-3">
                        <label class="form-label">Puntuación</label>
                        <select name="calificacion" class="form-select" required>
                            <option value="5">⭐⭐⭐⭐⭐ (Excelente)</option>
                            <option value="4">⭐⭐⭐⭐ (Muy bueno)</option>
                            <option value="3">⭐⭐⭐ (Bueno)</option>
                            <option value="2">⭐⭐ (Regular)</option>
                            <option value="1">⭐ (Malo)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Comentario</label>
                        <textarea name="comentario" class="form-control" rows="3" placeholder="Cuéntanos tu experiencia..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Enviar Reseña</button>
                </form>
            </div>
        </div>
    </div>
</div>
<%- include('../partials/footer') %>