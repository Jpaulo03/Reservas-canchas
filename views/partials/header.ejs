<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Canchas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="container">
        <a class="navbar-brand" href="/canchas">ReservaCanchas</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link" href="/canchas">Inicio</a></li>
                <% if (locals.user) { %>
                    <li class="nav-item"><a class="nav-link" href="/mis-reservas">Mis Reservas</a></li>
                    <% if (locals.user.rol === 'admin') { %>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-warning" href="#" role="button" data-bs-toggle="dropdown">Admin</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/canchas/nueva">Nueva Cancha</a></li>
                                <li><a class="dropdown-item" href="/admin/tipos">Gestionar Tipos</a></li>
                                <li><a class="dropdown-item" href="/admin/reservas">Todas las Reservas</a></li>
                            </ul>
                        </li>
                    <% } %>
                <% } %>
            </ul>
            <div class="d-flex">
                <% if (locals.user) { %>
                    <span class="navbar-text me-3">Hola, <strong><%= user.nombre %></strong></span>
                    <a href="/logout" class="btn btn-outline-danger btn-sm">Salir</a>
                <% } else { %>
                    <a href="/login" class="btn btn-outline-light me-2">Login</a>
                    <a href="/register" class="btn btn-primary">Registro</a>
                <% } %>
            </div>
        </div>
    </div>
</nav>
<main class="container">